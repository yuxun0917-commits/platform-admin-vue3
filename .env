# the base url of the application, the default is "/"
# if use a sub directory, it must be end with "/", like "/admin/" but not "/admin"
VITE_BASE_URL=/manager/

VITE_APP_TITLE=Galaxy Admin

VITE_APP_DESC=Galaxy Admin is a fresh and elegant admin template

# the prefix of the icon name
VITE_ICON_PREFIX=icon

# the prefix of the local svg icon component, must include VITE_ICON_PREFIX
# format {VITE_ICON_PREFIX}-{local icon name}
VITE_ICON_LOCAL_PREFIX=icon-local

# auth route mode: static ｜ dynamic
VITE_AUTH_ROUTE_MODE=static

# static auth route home
VITE_ROUTE_HOME=dashboard

# default menu icon
VITE_MENU_ICON=mdi:menu

# whether to enable http proxy when is dev mode
VITE_HTTP_PROXY=N

# vue-router mode: hash | history | memory
VITE_ROUTER_HISTORY_MODE=history

# success code of backend service, when the code is received, the request is successful
# aligned with backend Result: ErrorCode.SUCCESS = 200
VITE_SERVICE_SUCCESS_CODE=200

# logout codes of backend service, when the code is received, the user will be logged out and redirected to login page
# aligned with backend ErrorCode.UNAUTHORIZED = 10003 (未登录或登录已过期)
VITE_SERVICE_LOGOUT_CODES=10003

# second-factor (2FA) required codes of backend service
# when the code is received, it means the current operation needs a second-factor (password) verification,
# treated as a recognizable state (NOT an error) so the frontend can branch on it
# aligned with backend ErrorCode.SECOND_FACTOR_REQUIRED = 10009
VITE_SERVICE_SECOND_FACTOR_CODES=10009

# no-permission codes of backend service, when the code is received, redirect to the 403 no-permission page
# aligned with backend ErrorCode.FORBIDDEN / NO_PERMISSION = 10004 (无权限访问)
VITE_SERVICE_NO_PERMISSION_CODES=10004

# modal logout codes of backend service (backend ErrorCode has no such code, left empty)
VITE_SERVICE_MODAL_LOGOUT_CODES=

# token expired codes of backend service (backend returns 10003 for expired token, handled by logout codes above)
VITE_SERVICE_EXPIRED_TOKEN_CODES=

# when the route mode is static, the defined super role
VITE_STATIC_SUPER_ROLE=R_SUPER

# Used to differentiate storage across different domains
VITE_STORAGE_PREFIX=SOY_

# used to control whether the program automatically detects updates
VITE_AUTOMATICALLY_DETECT_UPDATE=Y
